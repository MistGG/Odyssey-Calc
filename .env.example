# API URL for production (Cloudflare Worker proxy recommended for CORS)
VITE_WIKI_API_BASE=https://odyssey-proxy.qawsar-ahmed.workers.dev/proxy/api/wiki

# For GitHub Pages project sites, set your repo base path:
# VITE_BASE_PATH=/your-repo-name/

# Origin for /models/… portraits (default thedigitalodyssey.com)
# VITE_WIKI_SITE_ORIGIN=https://thedigitalodyssey.com

# Optional full portrait URL override (placeholders: {model_id}, {id}, {name})
# VITE_WIKI_DIGIMON_IMAGE_TEMPLATE=https://example.com/models/{model_id}l.png

# VITE_WIKI_DIGIMON_PER_PAGE=500
