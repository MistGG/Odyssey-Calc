# Wiki API base URL (see hosting / env docs for production values)
# VITE_WIKI_API_BASE=

# GitHub Pages project site base path (if not deployed at domain root)
# VITE_BASE_PATH=/Odyssey-Calc/

# Supabase (auth + community rotations); set in your host’s env for production builds
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# Meter Discord previews: run the meter_profile_shares SQL in the Supabase SQL editor (see project docs or chat).
# Share links use your site (/share/meter-player/...), not Supabase URLs. CI sync:meter-shares copies previews into public/ before build.
