# Wiki API base URL (see hosting / env docs for production values)
# VITE_WIKI_API_BASE=

# App URL (custom domain). Use / for odyssey-calc.com; use /Odyssey-Calc/ only for github.io project pages.
# VITE_BASE_PATH=/
# VITE_SITE_ORIGIN=https://odyssey-calc.com

# Supabase (auth + community rotations); set in your host’s env for production builds
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# Meter Discord previews: run the meter_profile_shares SQL in the Supabase SQL editor (see project docs or chat).
# Production share links use the Worker on your domain (see workers/README.md):
# VITE_METER_SHARE_PUBLIC_ORIGIN=https://share.odyssey-calc.com
